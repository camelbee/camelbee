<?xml version="1.0" encoding="UTF-8"?>
<!-- Test-only logging config: provides a working MDC adapter (required by MdcContext tests)
     while keeping the test output quiet. -->
<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- Exercise the debug-guarded MDC enrichment branch in LoggingService. -->
  <logger name="org.camelbee.logging" level="DEBUG"/>

  <root level="WARN">
    <appender-ref ref="STDOUT"/>
  </root>
</configuration>
