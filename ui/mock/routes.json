          "description": "To[direct:musicianProcessor]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        }
      ]
    },
    {
      "id": "mongodbConsumerRoute",
      "input": "From[mongodb:mongoClient?database=camelbee&collection=musicians-in&createCollection=true]",
      "rest": false,
      "errorHandler": "direct:errorHandler",
      "outputs": [
        {
          "id": "to11",
          "description": "To[direct:musicianProcessor]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        }
      ]
    },
    {
      "id": "musicianProcessorRoute",
      "input": "From[direct:musicianProcessor]",
      "rest": false,
      "errorHandler": "direct:errorHandler",
      "outputs": [
        {
          "id": "to12",
          "description": "To[direct:invokeHttpBin]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        },
        {
          "id": "to13",
          "description": "To[direct:invokeKafka]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        },
        {
          "id": "to14",
          "description": "To[direct:invokeMqtt]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        },
        {
          "id": "to15",
          "description": "To[direct:invokeMockC]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        },
        {
          "id": "toD1",
          "description": "DynamicTo[direct:invokeJms]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDynamicDefinition",
          "outputs": []
        },
        {
          "id": "enrich1",
          "description": "Enrich[constant{direct:invokeMongoDb}]",
          "delimiter": null,
          "type": "org.apache.camel.model.EnrichDefinition",
          "outputs": []
        },
        {
          "id": "recipientList1",
          "description": "RecipientList[constant{direct:invokeFile,direct:invokeMockA}]",
          "delimiter": ",",
          "type": "org.apache.camel.model.RecipientListDefinition",
          "outputs": []
        },
        {
          "id": "routingSlip1",
          "description": "RoutingSlip[constant{direct:invokeMockB}]",
          "delimiter": ",",
          "type": "org.apache.camel.model.RoutingSlipDefinition",
          "outputs": []
        }
      ]
    },
    {
      "id": "invokeHttpBinRoute",
      "input": "From[direct:invokeHttpBin]",
      "rest": false,
      "errorHandler": "direct:errorHandler",
      "outputs": [
        {
          "id": "httpBinEndpoint",
          "description": "DynamicTo[http:localhost/stream/${header.hhId}?bridgeEndpoint=true]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDynamicDefinition",
          "outputs": []
        }
      ]
    },
