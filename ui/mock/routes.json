          "description": "To[direct:musicianProcessor]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        }
      ]
    },
    {
      "id": "jmsConsumerRoute",
      "input": "From[jms:queue:camelbee-northbound-queue?disableReplyTo=true&jmsMessageType=Text]",
