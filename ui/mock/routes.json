          "id": "to8",
          "description": "To[direct:musicianProcessor]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        }
      ]
    },
    {
      "id": "timerRoute",
      "input": "From[timer://foo?fixedRate=true&period=500000]",
      "rest": false,
      "errorHandler": "direct:errorHandler",
      "outputs": [
        {
          "id": "to9",
          "description": "To[direct:musicianProcessor]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        }
      ]
    },
