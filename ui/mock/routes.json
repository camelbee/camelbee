          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        }
      ]
    },
    {
      "id": "invokeJmsRoute",
      "input": "From[direct:invokeJms]",
      "rest": false,
      "errorHandler": "direct:errorHandler",
      "outputs": [
        {
          "id": "jmsEndpoint",
          "description": "To[jms:queue:camelbee-southbound-queue?disableReplyTo=true&jmsMessageType=Text]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        }
      ]
    },
    {
      "id": "invokeMongoDbRoute",
      "input": "From[direct:invokeMongoDb]",
      "rest": false,
      "errorHandler": "direct:errorHandler",
      "outputs": [
        {
          "id": "mongoDbEndpoint",
          "description": "To[mongodb:mongoClient?database=camelbee&collection=musicians-out&operation=insert]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        }
      ]
    },
    {
      "id": "invokeFileRoute",
      "input": "From[direct:invokeFile]",
      "rest": false,
      "errorHandler": "direct:errorHandler",
      "outputs": [
        {
          "id": "fileEndpoint",
          "description": "To[file://outputdir]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
