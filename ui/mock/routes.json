{
  "name": "camelbee-quarkus-sample",
  "jvm": "Eclipse Adoptium - 21.0.2",
  "jvmInputParameters": "-Xmx1024m -Xms512m -XX:+UseG1GC -Dquarkus.http.host=0.0.0.0",
  "garbageCollectors": "G1 Young Generation, G1 Old Generation",
  "framework": "Quarkus - 3.30.6",
  "camelVersion": "4.16.0",
  "routes": [
    {
      "id": "errorHandlerRoute",
      "input": "From[direct:errorHandler]",
      "rest": false,
      "errorHandler": null,
      "outputs": [
        {
          "id": "to-error-log",
          "description": "To[log:error-handler?level=ERROR]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        },
        {
          "id": "to-error-mock",
          "description": "To[mock:error]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        }
      ]
    },
    {
      "id": "postMusician",
      "input": "From[rest://post:/testapi/v1/musician?consumerComponentName=platform-http&consumes=application%2Fjson&description=Save+a+musician&produces=application%2Fjson&routeId=postMusician]",
      "rest": true,
      "errorHandler": null,
      "outputs": [
        {
          "id": "to1",
          "description": "To[direct:postMusician]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        }
      ]
    },
    {
      "id": "getMusician",
      "input": "From[rest://get:/testapi/v1/musician?consumerComponentName=platform-http&description=Get+a+musician&produces=application%2Fjson&routeId=getMusician]",
      "rest": true,
      "errorHandler": null,
      "outputs": [
        {
          "id": "to2",
          "description": "To[direct:getMusician]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        }
      ]
    },
    {
      "id": "postMusicianRoute",
      "input": "From[direct:postMusician]",
      "rest": false,
      "errorHandler": "direct:errorHandler",
      "outputs": [
        {
          "id": "to3",
          "description": "To[bean-validator://camelbee]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        },
        {
          "id": "to4",
          "description": "To[direct:musicianProcessor]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        }
      ]
    },
    {
      "id": "getMusicianRoute",
      "input": "From[direct:getMusician]",
      "rest": false,
      "errorHandler": "direct:errorHandler",
