      "input": "From[direct:invokeMockB]",
      "rest": false,
      "errorHandler": "direct:errorHandler",
      "outputs": [
        {
          "id": "mockBEndpoint",
          "description": "To[mock:B]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        }
      ]
    },
    {
      "id": "invokeMockCRoute",
      "input": "From[direct:invokeMockC]",
      "rest": false,
      "errorHandler": "direct:errorHandler",
      "outputs": [
        {
          "id": "mockCEndpoint",
          "description": "To[mock:C]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
