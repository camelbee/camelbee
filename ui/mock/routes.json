        {
          "id": "to5",
          "description": "To[direct:musicianProcessor]",
          "delimiter": null,
          "type": "org.apache.camel.model.ToDefinition",
          "outputs": []
        }
      ]
    },
    {
      "id": "kafkaConsumerRoute",
      "input": "From[kafka:camelbee-northbound-topic]",
