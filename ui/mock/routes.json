    },
    {
      "id": "invokeMqttRoute",
      "input": "From[direct:invokeMqtt]",
      "rest": false,
      "errorHandler": "direct:errorHandler",
      "outputs": [
        {
          "id": "mqttEndpoint",
          "description": "To[paho-mqtt5:camelbee-southbound-topic?brokerUrl=tcp://localhost:1883]",
