<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logging backend for the standalone sample.

  The pattern surfaces the MDC values that CamelBee populates per exchange/message
  (requestId + transactionId from CamelBeeUnitOfWork, routeId/endpoint from LoggingService),
  so the structured logging is visible on the console. A no-op MDC backend such as slf4j-simple
  would leave these blank.
-->
<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} %-5level [req=%X{requestId:-} tx=%X{transactionId:-} route=%X{routeId:-} ep=%X{endpoint:-}] %logger{20} - %msg%n</pattern>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>
</configuration>
